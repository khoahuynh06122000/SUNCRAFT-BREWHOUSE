rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Deny
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Primitives
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAnonymous() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function getEmail() {
      return request.auth.token.get('email', '').lower();
    }

    // Fetch user role safely from user_configs collection
    function getUserRole() {
      // Sử dụng get().data.get() để tránh lỗi nếu tài liệu không tồn tại
      return isSignedIn() ? get(/databases/$(database)/documents/user_configs/$(getEmail())).data.get('role', 'VIEWER') : 'GUEST';
    }

    function isOwner() {
      return isSignedIn() && !isAnonymous() && (
        getEmail().upper() == 'KHOA.HUYNH.06.12.2000@GMAIL.COM' || 
        getUserRole() == 'OWNER'
      );
    }

    function isStaff() {
      return isSignedIn() && !isAnonymous() && (
        isOwner() || getUserRole() == 'STAFF'
      );
    }

    function isViewer() {
      return isSignedIn() && (
        isStaff() || 
        (!isAnonymous() && getUserRole() == 'VIEWER') ||
        isAnonymous()
      );
    }

    // -------------------------------------------------------------------------
    // Collections
    // -------------------------------------------------------------------------
    
    // 1. Transactions
    match /transactions/{transactionId} {
      allow read: if isViewer();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isOwner();
    }

    // 2. Revenue Records
    match /revenue/{recordId} {
      allow read: if isViewer();
      allow create, update: if isStaff();
      allow delete: if isOwner();
    }

    // 3. Partners
    match /partners/{partnerId} {
      allow read: if isViewer();
      allow create, update: if isStaff();
      allow delete: if isOwner();
    }

    // 4. User Configurations (Internal Security)
    match /user_configs/{username} {
      // Cho phép lấy thông tin cụ thể (get) để kiểm tra đăng nhập truyền thống
      // Nhưng không cho phép liệt kê toàn bộ danh sách (list)
      allow get: if true; 
      allow list: if isOwner();
      allow write: if isOwner();
    }
  }
}
