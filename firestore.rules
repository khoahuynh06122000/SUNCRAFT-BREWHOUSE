rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Deny
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Primitives
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAnonymous() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function getEmail() {
      return request.auth.token.get('email', '').lower();
    }

    // Fetch user role from user_configs collection
    function getUserRole() {
      return get(/databases/$(database)/documents/user_configs/$(getEmail())).data.role;
    }

    function isOwner() {
      return isSignedIn() && !isAnonymous() && (
        getEmail().upper() == 'KHOA.HUYNH.06.12.2000@GMAIL.COM' || 
        getUserRole() == 'OWNER'
      );
    }

    function isStaff() {
      return isSignedIn() && !isAnonymous() && (
        isOwner() || getUserRole() == 'STAFF'
      );
    }

    function isViewer() {
      return isSignedIn() && (
        isStaff() || 
        (!isAnonymous() && getUserRole() == 'VIEWER') ||
        isAnonymous()
      );
    }

    // -------------------------------------------------------------------------
    // Collections
    // -------------------------------------------------------------------------
    
    // 1. Transactions
    match /transactions/{transactionId} {
      allow read: if isViewer();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isOwner();
    }

    // 2. Revenue Records
    match /revenue/{recordId} {
      allow read: if isViewer();
      allow create, update: if isStaff();
      allow delete: if isOwner();
    }

    // 3. Partners
    match /partners/{partnerId} {
      allow read: if isViewer();
      allow create, update: if isStaff();
      allow delete: if isOwner();
    }

    // 4. User Configurations (Internal Security)
    match /user_configs/{email} {
      allow read: if isOwner() || (isSignedIn() && getEmail() == email.lower());
      allow write: if isOwner();
    }
  }
}
