rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Deny
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Primitives
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
    
    // Authorization checks
    function isKhoa() {
      // Return true only if the user is the specific owner email
      return isSignedIn() && request.auth.token.get('email', '').upper() == 'KHOA.HUYNH.06.12.2000@GMAIL.COM';
    }

    // -------------------------------------------------------------------------
    // Entities Validation
    // -------------------------------------------------------------------------
    
    // 1. Transactions (Inventory IN/OUT)
    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'date', 'type', 'productId', 'quantity', 'createdBy']) &&
             data.id is string && data.id.size() <= 128 &&
             data.date is string &&
             data.type in ['IN', 'OUT'] &&
             data.productId is string &&
             data.quantity is number && data.quantity >= 0 &&
             data.createdBy is string && data.createdBy.size() <= 200;
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidTransaction(incoming());
      allow delete: if isKhoa();
    }

    // 2. Revenue Records (Global System Data)
    function isValidRevenue(data) {
      return data.keys().hasAll(['id', 'date', 'productName', 'quantity', 'unitPrice', 'totalAmount', 'partnerName']) &&
             data.id is string &&
             data.quantity is number &&
             data.unitPrice is number &&
             data.totalAmount is number;
    }

    match /revenue/{recordId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidRevenue(incoming());
      allow delete: if isKhoa();
    }

    // 3. Partners
    function isValidPartner(data) {
      return data.keys().hasAll(['id', 'name', 'type']) &&
             data.name is string && data.name.size() <= 200 &&
             data.type in ['SUPPLIER', 'AGENT', 'RESTAURANT', 'INDIVIDUAL'];
    }

    match /partners/{partnerId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidPartner(incoming());
      allow delete: if isKhoa();
    }
  }
}
