{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Inventory movement records (IN/OUT)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["IN", "OUT"] },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "partnerId": { "type": "string" },
        "partnerName": { "type": "string" },
        "notes": { "type": "string" },
        "batchNumber": { "type": "string" },
        "evidencePhotoUrl": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "date", "type", "productId", "quantity", "createdBy"]
    },
    "RevenueRecord": {
      "title": "Revenue Record",
      "description": "Sales records from exported data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "productName": { "type": "string" },
        "materialCode": { "type": "string" },
        "unit": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "totalAmount": { "type": "number" },
        "vatAmount": { "type": "number" },
        "invoiceNumber": { "type": "string" },
        "partnerName": { "type": "string" },
        "partnerId": { "type": "string" },
        "deptCode": { "type": "string" }
      },
      "required": ["id", "date", "productName", "quantity", "unitPrice", "totalAmount", "partnerName"]
    },
    "Partner": {
      "title": "Partner",
      "description": "Agents, Restaurants, Suppliers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "type": { "type": "string", "enum": ["SUPPLIER", "AGENT", "RESTAURANT", "INDIVIDUAL"] }
      },
      "required": ["id", "name", "type"]
    }
  },
  "firestore": {
    "transactions": {
      "schema": "Transaction",
      "description": "Inventory movement records"
    },
    "revenue": {
      "schema": "RevenueRecord",
      "description": "System-wide sales data"
    },
    "partners": {
      "schema": "Partner",
      "description": "Official partner registry"
    }
  }
}
